{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "group_contacts": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "id": {
                        "type": "number"
                    }
                },
                "required": [
                    "name",
                    "id"
                ]
            }
        },
        "private_contacts": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "id": {
                        "type": "number"
                    }
                },
                "required": [
                    "name",
                    "id"
                ]
            }
        },
        "dmr_ids": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "id": {
                        "type": "number"
                    }
                },
                "required": [
                    "name",
                    "id"
                ]
            }
        },
        "default_dmr_id": {
            "type": "string"
        },
        "zones": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "channels": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "type": {
                                    "type": "string"
                                },
                                "uplink": {
                                    "type": "number"
                                },
                                "downlink": {
                                    "type": "number"
                                },
                                "contacts": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            },
                            "required": [
                                "type",
                                "uplink",
                                "downlink",
                                "contacts"
                            ]
                        }
                    }
                },
                "required": [
                    "name",
                    "channels"
                ]
            }
        }
    },
    "required": [
        "group_contacts",
        "private_contacts",
        "dmr_ids",
        "default_dmr_id",
        "zones"
    ]
}